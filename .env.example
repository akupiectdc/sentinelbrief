# SentinelBrief example configuration.
# Copy to .env and adjust for your local environment.
# Never commit a real .env file or any secrets.

# Local-only restricted mode. When true, only local services are allowed
# and any cloud provider configuration is rejected (fail fast).
RESTRICTED_MODE=true

# Providers. Only "ollama" is implemented in the MVP.
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Local Ollama (LLM + embeddings).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Local Qdrant vector database.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sentinelbrief_documents

# Python ai-service.
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000

# C# web-api gateway.
WEB_API_PORT=8080
WEB_API_URL=http://localhost:8080

# Retrieval tuning.
TOP_K=5
MIN_RETRIEVAL_SCORE=0.25

# Chunking.
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Logging.
LOG_LEVEL=INFO
